# ─────────────────────────────────────────────────────────────
# Libra environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.
#
# Nothing here is used yet (Step 1 is the landing page only).
# These placeholders are reserved for upcoming steps:
#   • Supabase (Auth + Postgres + Row Level Security)
#   • The AI assistant provider
# ─────────────────────────────────────────────────────────────

# Supabase — added in a later step
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix with NEXT_PUBLIC_ and never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# AI assistant — added in a later step
ANTHROPIC_API_KEY=
