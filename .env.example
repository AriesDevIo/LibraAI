# ─────────────────────────────────────────────────────────────
# Libra environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.
#
# ─────────────────────────────────────────────────────────────

# Public site origin — used to build the magic-link callback URL.
# Set to your real domain in production (e.g. https://libra.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Auth + Postgres + Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix with NEXT_PUBLIC_ and never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# AI assistant — added in a later step
ANTHROPIC_API_KEY=
